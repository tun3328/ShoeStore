@model IEnumerable<EshopperMCV.Models.Product>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.ProName)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.ProImage)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.ProPrice)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Category.CatName)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.ProName)
        </td>
        <td>
            @*@Html.DisplayFor(modelItem => item.ProImage)*@
            <img src="~/images/shop/@item.ProImage" alt="" style="max-width:100px; max-height:100px;" />
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.ProPrice)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Category.CatName)
        </td>
        <td>
            @if (User.IsInRole("Admin"))
            {
                @Html.ActionLink("Edit", "Edit", new { id = item.ProId }) <text>|</text>
                @Html.ActionLink("Details", "Details", new { id = item.ProId }) <text>|</text>
            }
            @Html.ActionLink("Delete", "Delete", new { id = item.ProId })
        </td>
    </tr>
}

</table>
