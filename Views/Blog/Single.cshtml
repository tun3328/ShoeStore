@model List<EshopperMCV.Models.CommentViewModel>
@{
    ViewBag.Title = "Single";
    Layout = "~/Views/Shared/_EShopper_Layout.cshtml";
}

<section>
    <div class="container">
        <div class="row">
            @Html.Action("GetCategories", "Product")
            <div class="col-sm-9">
                <div class="blog-post-area">
                    <h2 class="title text-center">Latest From our Blog</h2>
                    <div class="single-blog-post">
                        <h3>New Sneaker Collection Now Available</h3>
                        <div class="post-meta">
                            <ul>
                                <li><i class="fa fa-user"></i> Mac Doe</li>
                                <li><i class="fa fa-clock-o"></i> 5:36 pm</li>
                                <li><i class="fa fa-calendar"></i> JAN 10, 2014</li>
                            </ul>
                            <span>
                                <i class="fa fa-star"></i>
                                <i class="fa fa-star"></i>
                                <i class="fa fa-star"></i>
                                <i class="fa fa-star"></i>
                                <i class="fa fa-star-half-o"></i>
                            </span>
                        </div>
                        <a href="">
                            <img src="~/images/blog/blog1.jpg" alt="">
                        </a>
                        <p>
                            Step into comfort and style with our latest shoe collection. Designed for everyday wear, our footwear combines modern design, breathable materials, and durable soles to support you throughout the day.
                        </p> <br>

                        <p>
                            Every pair is carefully crafted to deliver the perfect balance between performance and fashion. From casual sneakers to professional footwear, our shoes are made to fit your lifestyle and move with confidence.
                        </p> <br>

                        <p>
                            We focus on quality, comfort, and long-lasting durability, ensuring each step feels natural and supported no matter where your day takes you.
                        </p> <br>

                        <p>
                            Discover footwear that not only looks great but also provides reliable comfort, stability, and value for everyday use.
                        </p>
                        <div class="pager-area">
                            <ul class="pager pull-right">
                                <li><a href="#">Pre</a></li>
                                <li><a href="#">Next</a></li>
                            </ul>
                        </div>
                    </div>
                </div><!--/blog-post-area-->

                <div class="rating-area">
                    <ul class="ratings">
                        <li class="rate-this">Rate this item:</li>
                        <li>
                            <i class="fa fa-star color"></i>
                            <i class="fa fa-star color"></i>
                            <i class="fa fa-star color"></i>
                            <i class="fa fa-star"></i>
                            <i class="fa fa-star"></i>
                        </li>
                        <li class="color">(6 votes)</li>
                    </ul>
                    <ul class="tag">
                        <li>TAG:</li>
                        <li><a class="color" href="">Pink <span>/</span></a></li>
                        <li><a class="color" href="">T-Shirt <span>/</span></a></li>
                        <li><a class="color" href="">Girls</a></li>
                    </ul>
                </div><!--/rating-area-->

                <div class="socials-share">
                    <a href=""><img src="~/images/blog/socials.png" alt=""></a>
                </div><!--/socials-share-->

                <div class="media commnets">
                    <a class="pull-left" href="#">
                        <img class="media-object" src="~/images/blog/man-one.jpg" alt="">
                    </a>
                    <div class="media-body">
                        <h4 class="media-heading">Annie Davis</h4>
                        <p>
                            Passionate about footwear and fashion, Annie shares insights on the latest shoe trends, comfort technology, and tips to help you choose the perfect pair.
                        </p>
                        <div class="blog-socials">
                            <ul>
                                <li><a href=""><i class="fa fa-facebook"></i></a></li>
                                <li><a href=""><i class="fa fa-twitter"></i></a></li>
                                <li><a href=""><i class="fa fa-dribbble"></i></a></li>
                                <li><a href=""><i class="fa fa-google-plus"></i></a></li>
                            </ul>
                            <a class="btn btn-primary" href="">Other Posts</a>
                        </div>
                    </div>
                </div><!--Comments-->
                <div class="response-area">
                    <h2>@Model.Count RESPONSES</h2>
                    <ul class="media-list">
                        @foreach (var item in Model)
                        {
                            <li class="media">
                                <a class="pull-left" href="#">
                                    <img class="media-object" src="~/images/blog/man-two.jpg" alt="">
                                </a>
                                <div class="media-body">
                                    <ul class="sinlge-post-meta">
                                        <li><i class="fa fa-user"></i>@item.Name</li>
                                        <li><i class="fa fa-clock-o"></i>@item.CreatedAt.ToString("hh:mm tt")</li>
                                        <li><i class="fa fa-calendar"></i>@item.CreatedAt.ToString("MMM dd, yyyy")</li>
                                    </ul>
                                    <p>@item.Message</p>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
                <!--/Response-area-->
                <div class="replay-box">
                    <div class="row">
                        <div class="col-sm-12">
                            <h2>Leave a reply</h2>

                            @using (Html.BeginForm("PostComment", "Blog", FormMethod.Post))
                            {
                                <div class="form-group">
                                    <label>Your Name *</label>
                                    <input type="text" name="Name" class="form-control" required />
                                </div>

                                <div class="form-group">
                                    <label>Email Address *</label>
                                    <input type="email" name="Email" class="form-control" required />
                                </div>

                                <div class="form-group">
                                    <label>Your Comment *</label>
                                    <textarea name="Message" rows="6" class="form-control" required></textarea>
                                </div>

                                <button type="submit" class="btn btn-primary">
                                    Post Comment
                                </button>
                            }
                        </div>
                    </div>
                </div>
                <!--/Repaly Box-->
            </div>
        </div>
    </div>
</section>

